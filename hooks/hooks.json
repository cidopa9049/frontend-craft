{
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/security-check.mjs\"",
                        "timeout": 20,
                        "statusMessage": "Checking command safety..."
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Write|Edit|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/format-changed-file.mjs\"",
                        "timeout": 180,
                        "statusMessage": "Running formatter..."
                    }
                ]
            }
        ],
        "SessionStart": [
            {
                "matcher": ".*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/session-start.mjs\"",
                        "timeout": 10
                    }
                ]
            }
        ],
        "Stop": [
            {
                "matcher": ".*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/run-tests.mjs\"",
                        "timeout": 300,
                        "statusMessage": "Running final validation..."
                    }
                ]
            }
        ],
        "Notification": [
            {
                "matcher": ".*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/notify.mjs\""
                    }
                ]
            }
        ]
    }
}
